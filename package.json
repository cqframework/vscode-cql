{
  "name": "cql",
  "version": "0.9.0",
  "displayName": "Clinical Quality Language (CQL)",
  "description": "Syntax highlighting, linting, and execution for the HL7 Clinical Quality Language (CQL) for VS Code",
  "publisher": "cqframework",
  "license": "Apache-2.0",
  "author": "Alphora",
  "bugs": "https://github.com/cqframework/vscode-cql/issues",
  "keywords": [
    "cqframework",
    "clinical quality language",
    "cql",
    "fhir",
    "hl7"
  ],
  "icon": "icons/cqframework.png",
  "preview": true,
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    },
    "virtualWorkspaces": false
  },
  "engines": {
    "vscode": ">=1.75.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cqframework/vscode-cql"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Snippets"
  ],
  "main": "./dist/extension",
  "contributes": {
    "languages": [
      {
        "id": "cql",
        "extensions": [
          ".cql"
        ],
        "configuration": "./language-configuration.json",
        "aliases": [
          "CQL",
          "Cql"
        ]
      }
    ],
    "snippets": [
      {
        "language": "cql",
        "path": "./snippets.json"
      }
    ],
    "grammars": [
      {
        "language": "cql",
        "scopeName": "source.cql",
        "path": "./syntaxes/cql.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "CQL"
    },
    "commands": [
      {
        "command": "cql.open.serverLog",
        "title": "Open Server Logs",
        "category": "CQL"
      },
      {
        "command": "cql.open.clientLog",
        "title": "Open Client Logs",
        "category": "CQL"
      },
      {
        "command": "cql.open.logs",
        "title": "Open Logs",
        "category": "CQL"
      },
      {
        "command": "cql.action.viewElm",
        "title": "View ELM",
        "category": "CQL"
      },
      {
        "command": "cql.action.executeCql",
        "title": "Execute CQL",
        "category": "CQL"
      },
      {
        "command": "cqlExplorer.itemClicked",
        "title": "Item Clicked"
      },
      {
        "command": "cqlExplorer.library.execute",
        "title": "Execute"
      },
      {
        "command": "cqlExplorer.library.rename",
        "title": "Rename"
      },
      {
        "command": "cqlExplorer.library.hide",
        "title": "Hide"
      },
      {
        "command": "cqlExplorer.testCases.executeAll",
        "title": "Execute All"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "cql.action.viewElm",
          "when": "editorLangId == cql",
          "group": "1_cqlactions"
        },
        {
          "command": "cql.action.executeCql",
          "when": "editorLangId == cql",
          "group": "1_cqlactions"
        }
      ],
      "view/item/context": [
        {
          "command": "cqlExplorer.itemClicked",
          "when": "view == cql-libraries && viewItem == cqlItem"
        },
        {
          "command": "cqlExplorer.library.execute",
          "when": "view == cql-libraries && viewItem == library"
        },
        {
          "command": "cqlExplorer.library.rename",
          "when": "view == cql-libraries && viewItem == library"
        },
        {
          "command": "cqlExplorer.library.hide",
          "when": "view == cql-libraries && viewItem == library"
        },
        {
          "command": "cqlExplorer.testCase.executeAll",
          "when": "view == cql-libraries && viewItem == testCaseRoot"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cql-explorer",
          "title": "CQL Explorer",
          "icon": "icons/cqframework.png"
        }
      ]
    },
    "views": {
      "cql-explorer": [
        {
          "id": "cql-libraries",
          "name": "Libraries"
        }
      ]
    }
  },
  "resolutions": {
    "color-name": "1.1.3"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && npm run compile",
    "test": "vscode-test",
    "changelog": "node scripts/update-changelog.js"
  },
  "javaDependencies": {
    "cql-language-server": {
      "groupId": "org.opencds.cqf.cql.ls",
      "artifactId": "cql-ls-service",
      "version": "4.1.2"
    }
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/expand-tilde": "^2.0.0",
    "@types/fs-extra": "^9.0.13",
    "@types/glob": "^7.1.1",
    "@types/lodash": "^4.14.183",
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.18.34",
    "@types/node-fetch": "^2.6.2",
    "@types/vscode": "^1.73.0",
    "@types/winreg": "^1.2.31",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.6",
    "chai": "4.5",
    "mocha": "^10.8.2",
    "nyc": "^17.1.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "expand-tilde": "^2.0.2",
    "find-java-home": "1.2.2",
    "fs-extra": "^8.1.0",
    "glob": "^7.2.3",
    "lodash": "^4.17.21",
    "node-fetch": "2.6.7",
    "tslib": "^2.4.0",
    "vscode-languageclient": "^7.0.0",
    "vscode-uri": "^3.0.8",
    "winreg": "^1.2.4",
    "winston": "^3.8.1",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "tabWidth": 2,
    "arrowParens": "avoid"
  }
}
